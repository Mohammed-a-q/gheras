{
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c \"uvicorn main:app --host 0.0.0.0 --port $PORT --workers 1\"",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "healthcheck": {
      "path": "/health",
      "interval": 30,
      "timeout": 10,
      "maxRetries": 5
    }
  }
}
